# DO NOT COMMIT ACTUAL KEYS TO GIT!
# Copy this file to .env.local and fill in your values for local development.

# =============================================================================
# Firebase Configuration (Required in production)
# =============================================================================
# Get these values from Firebase Console > Project Settings > General > Your apps
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# =============================================================================
# App Check (optional — attestation for Firestore/Functions/Storage)
# =============================================================================
# Leave blank to disable App Check entirely (default). Set the reCAPTCHA v3 /
# Enterprise site key to enable it — start monitor-only in the Firebase console,
# then flip enforcement on once metrics show legitimate traffic is verified.
VITE_APPCHECK_RECAPTCHA_SITE_KEY=
# Debug token for local/emulator development (register it in the console).
VITE_APPCHECK_DEBUG_TOKEN=

# =============================================================================
# Error Reporting (optional — production crash observability)
# =============================================================================
# When set, uncaught errors, unhandled rejections, and error-boundary catches
# are POSTed here as structured JSON (Sentry tunnel, log endpoint, etc.). Leave
# blank to fall back to console-only (default). See src/lib/errorReporter.ts.
VITE_ERROR_REPORTING_ENDPOINT=
# Release identifier attached to reports (e.g. a git SHA); defaults to "dev".
VITE_APP_VERSION=

# =============================================================================
# Admin Configuration (Required in production)
# =============================================================================
# Comma-separated list of Firebase UIDs that have admin access
VITE_ADMIN_UIDS=uid1,uid2,uid3

# =============================================================================
# YouTube API (Optional - enables embedded video playback)
# =============================================================================
# Get from: https://console.cloud.google.com/apis/credentials
# Enable: YouTube Data API v3
VITE_YOUTUBE_API_KEY=your_youtube_api_key_here

# =============================================================================
# Optional Configuration
# =============================================================================
# Override app name
# VITE_APP_NAME=marching.art

# Override data namespace
# VITE_DATA_NAMESPACE=marching-art

# Support email
# VITE_SUPPORT_EMAIL=support@marching.art

# =============================================================================
# Development Only
# =============================================================================
# Use Firebase emulators
# VITE_USE_EMULATORS=true

# Enable verbose logging
# VITE_VERBOSE_LOGGING=true

# =============================================================================
# Cloud Functions Secrets (NOT environment variables)
# =============================================================================
# These are NOT stored in .env files. They are set using Firebase secrets:
#
# BREVO_API_KEY - Required for email notifications
#   Set via: firebase functions:secrets:set BREVO_API_KEY
#   Get from: https://app.brevo.com/settings/keys/api
#
# SCRAPER_API_KEY - Required for live DCI score scraping. dci.org sits behind a
#   Cloudflare "managed challenge", so fetches route through a JS-rendering
#   scraping API (ScrapingAnt / ScrapingBee / ZenRows / ScraperAPI) that solves
#   it. When unset, the scraper falls back to a direct GET (fine for local dev;
#   will 403 in prod).
#   Set via: firebase functions:secrets:set SCRAPER_API_KEY
#   Provider is set by the SCRAPER_API_PROVIDER param in functions/.env.<project>
#   (scrapingant | scrapingbee | zenrows | scraperapi | custom); production uses
#   scrapingant (free tier). See docs/INTEGRATIONS.md → "Live DCI scraping".
#
# To set secrets for production:
#   firebase functions:secrets:set BREVO_API_KEY --project=YOUR_PROJECT_ID
