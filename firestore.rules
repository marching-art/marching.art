rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- COLLECTION GROUP QUERIES FOR LEADERBOARDS ---
    match /artifacts/{namespace}/users/{userId}/profile/data {
      allow read: if true; // Public profiles for leaderboards
    }
    
    match /{path=**}/data {
      allow read: if true; // This enables collectionGroup(db, 'data') queries
    }

    // --- ADMIN ACCESS ---
    match /{document=**} {
      allow read, write: if request.auth != null && 
        request.auth.uid == "o8vfRCOevjTKBY0k2dISlpiYiIH2";
    }

    // --- HELPER FUNCTIONS ---
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.admin == true || request.auth.uid == "o8vfRCOevjTKBY0k2dISlpiYiIH2");
    }

    // --- USER DATA ---
    match /artifacts/{namespace}/users/{userId} {
      // Profile data is readable by anyone (for public profiles, leaderboards, leagues, etc.)
      match /profile/data {
        allow read: if true; // Profiles are public
        allow create: if isOwner(userId);
        allow update: if isOwner(userId) && 
                        request.resource.data.keys().hasAll(['xp', 'corpsCoin', 'unlockedClasses']) &&
                        request.resource.data.uid == userId;
        allow delete: if false; // Never allow deletion of profiles
      }

      // NEW: Corps collection - each user can have multiple corps
      match /corps/{corpsId} {
        allow read: if isAuthenticated(); // All authenticated users can read corps
        allow create: if isOwner(userId) && 
                        request.resource.data.userId == userId;
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId) || isAdmin();
      }

      // Staff collection
      match /staff/{staffId} {
        allow read: if isAuthenticated();
        allow create: if isOwner(userId);
        allow update, delete: if isOwner(userId);
      }

      // Notifications collection
      match /notifications/{notificationId} {
        allow read: if isOwner(userId);
        allow update: if isOwner(userId) && 
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt']);
        allow create: if false; // Only cloud functions can create
        allow delete: if isOwner(userId);
      }

      // User settings
      match /settings/{document} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId);
      }

      // User collections (generic catch-all for other collections)
      match /{collection}/{document} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId);
      }
    }

    // --- PUBLIC DATA COLLECTIONS ---
    
    // Game Settings - Public read, admin write
    match /game-settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // DCI Data - Public read, admin write
    match /dci-data/{seasonId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /{path=**} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }
    
    // Historical Scores
    match /historical_scores/{year}/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Leaderboards
    match /leaderboards/{season}/{document=**} {
      allow read: if true;
      allow write: if false; // Backend only
    }

    // Fantasy Recaps
    match /fantasy_recaps/{season}/{document=**} {
      allow read: if isAuthenticated();
      allow write: if false; // Backend only
    }

    // Active Lineups - NEW: Per corps, not per user
    match /activeLineups/{seasonId}/{userId}/{corpsId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // Show Participants
    match /participants/{participantId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && 
                      request.auth.uid == resource.data.userId;
      allow delete: if isAuthenticated() && 
                      request.auth.uid == resource.data.userId;
    }

    // --- STAFF MARKETPLACE ---
    match /staff_marketplace/{listingId} {
      allow read: if isAuthenticated() && resource.data.isActive == true;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.sellerId;
      allow update: if isAuthenticated() && 
        (request.auth.uid == resource.data.sellerId || isAdmin());
      allow delete: if isAuthenticated() && 
        (request.auth.uid == resource.data.sellerId || isAdmin());
    }

    // --- LEAGUES ---
    match /leagues/{leagueId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false; // Backend only
      
      match /matchups/{week} {
        allow read: if isAuthenticated();
        allow write: if false; // Backend only
      }

      match /chat/{messageId} {
        allow read: if isAuthenticated() && 
          request.auth.uid in get(/databases/$(database)/documents/leagues/$(leagueId)).data.members;
        allow create: if isAuthenticated() && 
          request.auth.uid in get(/databases/$(database)/documents/leagues/$(leagueId)).data.members &&
          request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false; // Messages are immutable
      }
    }

    match /league_invitations/{inviteId} {
      allow read: if isAuthenticated() && 
        (request.auth.uid == resource.data.inviteeId || 
         request.auth.uid == resource.data.inviterId || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && 
        (request.auth.uid == resource.data.inviteeId || 
         request.auth.uid == resource.data.inviterId);
      allow delete: if isAuthenticated() && 
        (request.auth.uid == resource.data.inviterId || isAdmin());
    }

    // --- TRANSACTIONS ---
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && 
                    (resource.data.buyerId == request.auth.uid || 
                     resource.data.sellerId == request.auth.uid);
      allow write: if false; // Only cloud functions can write
    }

    match /corps_coin_transactions/{userId}/transactions/{transactionId} {
      allow read: if isAuthenticated() && 
        (request.auth.uid == userId || isAdmin());
      allow write: if false; // Backend only
    }

    match /xp_transactions/{userId}/transactions/{transactionId} {
      allow read: if isAuthenticated() && 
        (request.auth.uid == userId || isAdmin());
      allow write: if false; // Backend only
    }

    // --- HALL OF FAME & STAFF ---
    match /hall-of-fame/{memberId} {
      allow read: if true; // Public data
      allow write: if isAdmin();
    }

    match /staff-database/{staffId} {
      allow read: if true; // Public data
      allow write: if isAdmin();
    }

    // --- ACHIEVEMENTS ---
    match /achievements/{userId}/{achievementId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only cloud functions
    }

    // --- SYSTEM ---
    match /season-config/{seasonId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /system-logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /error-logs/{errorId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /backups/{backupId}/{document=**} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}