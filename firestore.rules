rules_version = '2';service cloud.firestore {match /databases/{database}/documents {// Helper functions
function isAuthenticated() {
  return request.auth != null;
}

function isAdmin() {
  // Admin access is determined by custom claims set via Firebase Admin SDK
  return isAuthenticated() && request.auth.token.admin == true;
}

function isOwner(userId) {
  return isAuthenticated() && request.auth.uid == userId;
}

// Profile fields that only backend code (Admin SDK bypasses rules) may set.
// Guards the game economy: currency, XP/level, class unlocks, career stats,
// and trophies must never be client-writable, and createdAt/username/uid are
// protected because unlock timing and username reservation depend on them.
// lifetimeStats feeds the lifetime leaderboards and activeSeasonId /
// lastScoredDay drive the scoring engine, so they are server-only too.
// challenges is the daily-challenge completion ledger the
// completeDailyChallenge callable trusts for XP awards — client-writable
// completions could be cleared and re-claimed to farm XP. predictions and
// predictionStats are the daily-prediction ledger the resolvePredictions
// callable trusts for XP/coin bonuses, so they're server-only for the same
// reason.
// achievements carry CorpsCoin rewards (paid by the daily sweep in
// claimDailyLogin), lastRewardedLevel gates the level-up stipend, and
// journey is the First Season Journey completion ledger (each step pays
// XP + coin via completeJourneyStep) — all server-only like the rest of
// the economy.
// retiredCorps carries purchased memorial plaques (purchaseRetirementPlaque
// debits CorpsCoin for them), so a client-writable array would make plaques
// forgeable for free; every retire/unretire mutation already goes through
// callables.
// role is trusted server-side (admin email fan-out and the manual
// leaderboard/rivals refresh callables gate on it), so a client-writable
// role would be privilege escalation.
function touchesProtectedProfileFields() {
  return request.resource.data.diff(resource.data).affectedKeys().hasAny([
    'corpsCoin', 'xp', 'xpLevel', 'userTitle', 'unlockedClasses',
    'stats', 'trophies', 'username', 'createdAt', 'uid',
    'lifetimeStats', 'activeSeasonId', 'lastScoredDay', 'challenges',
    'predictions', 'predictionStats', 'achievements', 'lastRewardedLevel',
    'journey', 'cosmetics', 'seasonLadder', 'xpAtSeasonStart',
    'retiredCorps', 'captionStats', 'role',
    // Buy Me a Coffee supporter flair (tier + link). Granted only by the
    // BMAC webhook / linkBmacSupport callable after payment is verified; a
    // client write would let anyone forge a supporter badge for free.
    'supporter',
    // Hosting resume (hosting.byTier) gates the venue ladder — written only
    // by the nightly hosted-event payout pass; a client write would unlock
    // the NFL Stadium for free.
    'hosting'
  ]);
}

// The corps map itself stays client-writable because cosmetic fields
// (location, uniform design, ensemble identity) are edited from the dashboard
// and profile, and onboarding creates the soundSport corps client-side — but
// the subfields the scoring engine and leaderboards trust must only change
// through Cloud Functions:
//  - lineup/lineupKey/weeklyTrades via the saveLineup callable
//  - totalSeasonScore and seasonRank/seasonRankOf (nightly class standing,
//    "World Class · #14") via the scoring processors — a client-forged score
//    or rank would display on public profiles
//  - mustRename via renameCorps; corpsName is guarded too: corps identity is
//    permanent (retire and restart instead of renaming), so names are set
//    only at registration (registerCorps callable) and changed only by the
//    admin duplicate-rename flow
//  - seasonHistory and medals via season archival / the nightly processors:
//    archived placements feed the public resume AND the lifetime Director
//    Rating leaderboard, medals feed the trophy case — a client-forged
//    placement would mint leaderboard rank
//  - division (Podium A/Open/World seat) via season-boundary assessment —
//    a client-forged seat would display a stolen rise
//  - selectedShows via selectUserShows: show registrations drive competitive
//    score AND CorpsCoin payouts (the nightly scorer adds each attended
//    show's score to totalSeasonScore and mints SHOW_PARTICIPATION_REWARDS
//    coin per show), and the per-week/per-day caps live ONLY in the
//    callable — a direct client write would let a director "attend" every
//    show every day, forging rank and farming coin.
//
// PERF — EXPRESSION BUDGET: these guards run on EVERY owner update to
// profile/data. An earlier version compared each guarded subfield with its
// own request-vs-resource get() pair (12 pairs per class across four
// classes), and on fully built-out mid-season profiles (all classes
// registered, selectedShows/seasonHistory populated) the total evaluation
// exceeded Firestore's per-request rules evaluation budget. Firestore
// surfaces that as a plain PERMISSION_DENIED, so affected owners could not
// save ANY profile edit ("Failed to update profile"). The MapDiff form
// below (one diff + hasAny per class) enforces the same protection at a
// fraction of the cost. Do not revert to per-field get() pairs, and keep
// the corps short-circuit in touchesProtectedCorpsFields().

// A corps.{class} entry as a map for diffing. Missing and explicitly-null
// entries both normalize to {}: get()'s default only applies when the key is
// absent, and a director may have nulled out a class (deletion), so the
// explicit null has to be mapped too or diff() would error out.
function corpsEntry(data, corpsClass) {
  return data.get(['corps', corpsClass], null) == null
    ? {}
    : data.get(['corps', corpsClass], {});
}

// Deleting a whole class entry (setting it to null) stays allowed; a
// director can only zero out their own corps that way, not forge scores.
function corpsClassUntouched(corpsClass) {
  return request.resource.data.get(['corps', corpsClass], null) == null ||
    !request.resource.data.get(['corps', corpsClass], {})
      .diff(corpsEntry(resource.data, corpsClass))
      .affectedKeys()
      .hasAny(['lineup', 'lineupKey', 'weeklyTrades', 'mustRename', 'corpsName',
               'totalSeasonScore', 'seasonRank', 'seasonRankOf', 'seasonHistory',
               'medals', 'division', 'selectedShows']);
}

// Podium Class competitive state (corps.podiumClass.podium.*) is written
// exclusively by Cloud Functions: captions, condition, budget, staff and
// reputation ARE the game, so a client write here would be score forgery
// (PODIUM.md §14.2.5). Inert until podiumClass entries exist
// on profiles (Phase 2) — a missing entry passes untouched.
function podiumStateUntouched() {
  return request.resource.data.get(['corps', 'podiumClass'], null) == null ||
    request.resource.data.get(['corps', 'podiumClass', 'podium'], null)
      == resource.data.get(['corps', 'podiumClass', 'podium'], null);
}

// SoundSport lineups are created during client-side onboarding, so only its
// score is guarded; the three competitive classes get the full guard.
// podiumClass gets the standard class guard (name/score/rank) plus the
// podium-state guard above.
function touchesProtectedCorpsFields() {
  // Short-circuit (see PERF note above): writes that don't touch the corps
  // map at all — display name, director bio, settings, most profile writes —
  // skip every per-class guard.
  return request.resource.data.diff(resource.data).affectedKeys().hasAny(['corps']) &&
    (!corpsClassUntouched('worldClass') ||
     !corpsClassUntouched('openClass') ||
     !corpsClassUntouched('aClass') ||
     !corpsClassUntouched('podiumClass') ||
     !podiumStateUntouched() ||
     request.resource.data.get(['corps', 'soundSport', 'totalSeasonScore'], null)
       != resource.data.get(['corps', 'soundSport', 'totalSeasonScore'], null) ||
     // soundSport is scored from show attendance too (the scorer iterates every
     // class on the profile), so its selectedShows must be server-only as well;
     // corpsClassUntouched only covers the three competitive classes + podium.
     request.resource.data.get(['corps', 'soundSport', 'selectedShows'], null)
       != resource.data.get(['corps', 'soundSport', 'selectedShows'], null));
}

// --- USER DATA ---
// This path now uses {appId} to match our React code and guidelines

// Allow admins to list all users (needed for admin panel metrics)
match /artifacts/{appId}/users/{userId} {
  allow list: if isAdmin();

  // Profile data is public to read (leaderboards and public profiles).
  // Owners may update cosmetic/preference fields (corps details, settings,
  // display name, engagement, etc.) but NOT the protected
  // economy/progression fields (including the challenges ledger) — those
  // change only via Cloud Functions.
  // Creation is owned by the createUserProfile callable, which atomically
  // reserves the username server-side.
  match /profile/data {
    allow read: if true;
    allow create, delete: if isAdmin();
    allow update: if isAdmin() ||
      (isOwner(userId) && !touchesProtectedProfileFields() &&
        !touchesProtectedCorpsFields());
  }
  
  // Profile comments are public to read. Creation is backend-only: no client
  // code writes this subcollection (management goes through the deleteComment
  // callable), and the previous `allow create: if isAuthenticated()` let any
  // signed-in user create a comment attributed to ANY authorUid (impersonation)
  // with an arbitrary document shape. If client-side comment creation returns,
  // add a validated rule that requires
  // request.resource.data.authorUid == request.auth.uid and caps field sizes.
  match /comments/{commentId} {
    allow read: if true;
    allow create: if false; // Backend only
    allow update: if isAuthenticated() && request.auth.uid == resource.data.authorUid;
    allow delete: if isAuthenticated() &&
      (request.auth.uid == userId || request.auth.uid == resource.data.authorUid || isAdmin());
  }
  
  // Notifications are private
  match /notifications/{notificationId} {
    allow read, write: if isOwner(userId);
  }

  // Private data (email address, etc.) is readable ONLY by the owner or an
  // admin. This must be declared explicitly because Firestore rules are
  // additive: the broad catch-all below would otherwise expose it to every
  // authenticated user.
  match /private/{document=**} {
    allow read: if isOwner(userId) || isAdmin();
    allow write: if isOwner(userId) || isAdmin();
  }

  // All other user subcollections (like corps data, staff rosters, etc.)
  // can be read by any logged-in user (for leaderboards/profile viewing)
  // but only written to by the owner or an admin.
  // NOTE: `private` is explicitly excluded here — additive rule semantics mean
  // a stricter rule elsewhere cannot "override" a permissive match, so the
  // exclusion has to live on the permissive rule itself. Likewise
  // `corpsCoinHistory` is excluded from owner writes: it is the economy audit
  // trail and is written exclusively by Cloud Functions. `profile` must be
  // excluded too — without it, this catch-all silently granted owners
  // unrestricted writes to profile/data, bypassing the protected-field
  // guards above entirely (currency, XP, trophies, lineups, scores).
  // Podium competitive state (podium/state) is server-only for writes —
  // captions, condition, and reputation are the game — and OWNER-only for
  // reads: challenge levels and caption progress are competitive intel
  // (PODIUM.md §14.2.5). Public identity lives on profile/data.
  match /podium/{document=**} {
    allow read: if isAdmin() || isOwner(userId);
    allow write: if isAdmin();
  }

  // Catch-all for user subcollections WITHOUT a specific rule above.
  // INVERTED TO DEFAULT-PRIVATE (was a default-public denylist): the old
  // shape made any NEW subcollection world-readable-to-authenticated and
  // owner-writable unless someone remembered to exclude it — which is how
  // email_log (which emails each user was sent) ended up readable by any
  // signed-in account, and exactly the hazard the old comment warned about.
  //
  // Every surface a client actually reads or writes has its own explicit
  // match above (profile, comments, notifications, private, podium), so this
  // catch-all now only covers server-written data (corpsCoinHistory,
  // email_log, legacy corps docs, and anything added in the future): owners
  // and admins may read their own; writes are backend/admin-only. If a new
  // subcollection needs public reads or client writes, give it its OWN match
  // block with the tightest rule that works — do not re-widen this one.
  // `corpsCoinHistory` stays callable-only even for the owner (the
  // getCorpsCoinHistory callable owns pagination/shape) — a deliberate,
  // rules-test-pinned contract.
  match /{subcollection}/{document=**} {
    allow read: if isAdmin() || (isOwner(userId) && subcollection != 'corpsCoinHistory');
    allow write: if isAdmin();
  }
}

// Collection group query for private data (admin panel joins emails by uid).
// Restricted to admins; owners read their own doc via the path-based rule above.
match /{path=**}/private/{docId} {
  allow read: if isAdmin();
}

// Collection group query for profiles (needed for leaderboards/dashboard)
match /{path=**}/profile/{docId} {
  allow read: if isAuthenticated();
}

// --- BUY ME A COFFEE SUPPORTERS ---
// Fully locked: these docs hold PII (payer email + name) and are written only
// by the BMAC webhook / reconcile job / supporter callables via the Admin SDK.
// The public Supporters wall is served by the getSupportersWall callable, which
// redacts emails and honors the anonymous opt-out — so no client read/write.
match /artifacts/{appId}/supporters/{emailHash} {
  allow read, write: if false; // Backend only (see getSupportersWall)
}

// --- LEADERBOARD DATA ---
// Allow public read access to leaderboard subcollections
match /artifacts/{appId}/leaderboard/{timeframe}/{classType} {
  allow read: if true;
  allow write: if false; // Backend only
}

// Allow reading documents within leaderboard class collections
match /artifacts/{appId}/leaderboard/{timeframe}/{classType}/{docId} {
  allow read: if true;
  allow write: if false; // Backend only
}

// --- PUBLIC GAME DATA (READ-ONLY FOR USERS) ---
// This structure from your file is perfect.
match /game-settings/{docId} {
  allow read: if true;
  allow write: if isAdmin();
}

match /dci-data/{docId} {
  allow read: if true;
  allow write: if isAdmin();
 
  // Allow reading subcollections like corpsValues
  match /{subcollection}/{document=**} {
    allow read: if true;
    allow write: if isAdmin();
  }
}

match /dci-stats/{docId} {
  allow read: if true;
  allow write: if false; // Backend only
}

// Materialized season standings, written nightly by the scoring pipeline
// (helpers/standingsMaterializer.js). Public like the recaps they summarize;
// contains only ranked-class data (SoundSport scores are never included).
match /fantasy_standings/{seasonUid} {
  allow read: if true;
  allow write: if false; // Backend only

  match /classes/{classKey} {
    allow read: if true;
    allow write: if false; // Backend only
  }
}

match /fantasy_recaps/{docId} {
  allow read: if true;
  allow write: if false; // Backend only

  // Subcollection for daily recaps (OPTIMIZATION: one doc per day instead of array)
  match /days/{dayId} {
    allow read: if true;
    allow write: if false; // Backend only
  }
}

// Nightly score-drop plans — tonight's scrape/drop schedule, backend-written
// by the drop dispatcher (scheduled/dropDispatcher.js). Public so the client
// can show a real countdown to the night's drop time.
match /drop_plans/{showDate} {
  allow read: if true;
  allow write: if false; // Backend only
}

// Podium Class recap sheets — public like fantasy_recaps, backend-written by
// the nightly Podium stage (helpers/podium/processor.js).
match /podium-recaps/{seasonUid} {
  allow read: if true;
  allow write: if false; // Backend only

  match /days/{dayId} {
    allow read: if true;
    allow write: if false; // Backend only
  }

  // The Podium Report — weekly power-rankings column (Phase 7.3). Feeds the
  // weekly Podium Report news article.
  match /power/{weekId} {
    allow read: if true;
    allow write: if false; // Backend only
  }

  // Daily Podium Class standings sheet — full-field ranking snapshotted each
  // processing day (the Scores-tab standings view; the news column stays weekly).
  match /standings/{dayId} {
    allow read: if true;
    allow write: if false; // Backend only
  }
}

// Podium season roster — processor iteration index, backend only. Not
// readable by clients: standings/recaps are the public surfaces.
match /podium-season/{seasonUid}/{document=**} {
  allow read, write: if false; // Backend only
}

// Director-hosted events (all classes) — public event pages/history; all
// mutations go through the hostEvent callable and the nightly payout.
match /hosted-events/{seasonUid}/{document=**} {
  allow read: if true;
  allow write: if false; // Backend only
}

// Eastern Classic two-night lineups (all classes) — the published "who got
// Friday?" preview and the persisted final night assignment, written by the
// nightly scorers (helpers/easternSplit.js).
match /eastern-classic/{seasonUid} {
  allow read: if true;
  allow write: if false; // Backend only
}

// Podium joint-rehearsal proposals (design §5.12) — backend only; the
// propose/respond/list callables are the API (the scrimmage report is
// competitive intel and lives on the server-only podium state).
match /podium-joint/{seasonUid}/{document=**} {
  allow read, write: if false; // Backend only
}

// Podium funnel metrics (Phase 8.2) — operational telemetry for the admin
// panel; not player-facing.
match /podium-metrics/{seasonUid}/days/{dayId} {
  allow read: if isAdmin();
  allow write: if false; // Backend only
}

// Fan Favorite (decision 30): finalists + winner are public; individual
// ballots are private (server-only — the vote callables are the API).
match /podium-fan/{seasonUid} {
  allow read: if true;
  allow write: if false; // Backend only

  match /ballots/{voterUid} {
    allow read, write: if false; // Backend only — votes are private
  }
}

match /season_champions/{docId} {
  allow read: if true;
  allow write: if false; // Backend only
}

// All-time Records Book (game-records/records), maintained by the nightly
// scoring run and season archival.
match /game-records/{docId} {
  allow read: if true;
  allow write: if false; // Backend only
}

// Economy instrumentation (admin-stats/economy) — mint-vs-sink aggregates
// written weekly by economyStatsJob and rendered on the Admin page only.
match /admin-stats/{docId} {
  allow read: if isAdmin();
  allow write: if false; // Backend only
}

match /final_rankings/{docId} {
  allow read: if true;
  allow write: if isAdmin();
}

match /historical_scores/{docId} {
  allow read: if true;
  allow write: if false; // Backend only
}

match /historical_schedules/{docId} {
  allow read: if true;
  allow write: if false; // Backend only
}

match /schedules/{docId} {
  allow read: if true;
  allow write: if isAdmin();
}

// --- LEAGUES ---
// Updated to support new league features
match /artifacts/{appId}/leagues/{leagueId} {
  // SCOPED LIST: the live namespace's list requires a query that provably
  // matches one of three owning/public branches — where('isPublic','==',true)
  // (public-league browse), where('members','array-contains', own uid)
  // (my-leagues), or where('creatorId','==', own uid) (leagues I created).
  // Every client query in src/api/leagues.ts uses one of these shapes. An
  // UNCONSTRAINED list is denied: it used to expose every private league's
  // full doc (member UID arrays, settings) to any signed-in user.
  //
  // The frozen legacy 'fantasy_drum_corps_v1' namespace stays fully
  // listable: the landing/community widgets (src/api/community.ts) run
  // unconstrained queries over that archived, never-written-again data for
  // social-proof stats — see the NOTE in that file before changing this.
  //
  // Join secrets must STILL never live on the league doc (public leagues
  // remain listable): createLeague writes the code only to
  // /leagueInvites/{code} (client access closed below) and the member-only
  // meta/private subcollection doc (rule further down);
  // scripts/stripLeagueInviteCodes.js migrates legacy docs. Joining goes
  // through callables, which also enforce invitation checks for private
  // leagues.
  allow list: if isAuthenticated() &&
    (appId == 'fantasy_drum_corps_v1' ||
      resource.data.isPublic == true ||
      request.auth.uid in resource.data.members ||
      request.auth.uid == resource.data.creatorId);
  allow get: if isAuthenticated() &&
    (request.auth.uid in resource.data.members || isAdmin());
  allow write: if false; // Backend functions only

  // League standings
  match /standings/{docId} {
    allow read: if isAuthenticated() &&
      (request.auth.uid in get(/databases/$(database)/documents/artifacts/$(appId)/leagues/$(leagueId)).data.members || isAdmin());
    allow write: if false; // Backend only
  }

  // League matchups
  match /matchups/{week} {
    allow read: if isAuthenticated() &&
      (request.auth.uid in get(/databases/$(database)/documents/artifacts/$(appId)/leagues/$(leagueId)).data.members || isAdmin());
    allow write: if false; // Backend only
  }

  // League chat
  match /chat/{messageId} {
    allow read: if isAuthenticated() &&
      (request.auth.uid in get(/databases/$(database)/documents/artifacts/$(appId)/leagues/$(leagueId)).data.members || isAdmin());
    allow write: if false; // Backend only (via cloud function)
  }

  // League trades
  match /trades/{tradeId} {
    allow read: if isAuthenticated() &&
      (request.auth.uid in get(/databases/$(database)/documents/artifacts/$(appId)/leagues/$(leagueId)).data.members || isAdmin());
    allow write: if false; // Backend only
  }

  // League activity feed (system events: matchups, champions, joins).
  // Previously unmatched — Firestore denies unmatched paths, so the feed's
  // client reads silently failed and it always looked empty.
  match /activity/{eventId} {
    allow read: if isAuthenticated() &&
      (request.auth.uid in get(/databases/$(database)/documents/artifacts/$(appId)/leagues/$(leagueId)).data.members || isAdmin());
    allow write: if false; // Backend only
  }

  // Weekly recaps (generated by leagueAutomation)
  match /recaps/{week} {
    allow read: if isAuthenticated() &&
      (request.auth.uid in get(/databases/$(database)/documents/artifacts/$(appId)/leagues/$(leagueId)).data.members || isAdmin());
    allow write: if false; // Backend only
  }

  // League metadata, member-only: meta/rivalries (written by the rivalry
  // job) and meta/private (the league's invite code, written by createLeague
  // — kept off the listable league doc above so non-members can never
  // enumerate join secrets).
  match /meta/{docId} {
    allow read: if isAuthenticated() &&
      (request.auth.uid in get(/databases/$(database)/documents/artifacts/$(appId)/leagues/$(leagueId)).data.members || isAdmin());
    allow write: if false; // Backend only
  }

  // Daily prediction pools — escrowed CorpsCoin side-pots, entered via the
  // joinLeaguePool callable and settled by the nightly scoring run.
  match /pools/{gameDay} {
    allow read: if isAuthenticated() &&
      (request.auth.uid in get(/databases/$(database)/documents/artifacts/$(appId)/leagues/$(leagueId)).data.members || isAdmin());
    allow write: if false; // Backend only
  }
}

// League invite codes. Doc IDs ARE the secret join codes and docs carry the
// target leagueId; the joinLeagueByCode callable reads them with the Admin
// SDK, so no client access is needed. The previous
// `allow read: if isAuthenticated()` included LIST, letting any signed-in
// user enumerate every code and join any private league.
match /leagueInvites/{code} {
  allow read: if false; // Backend only (joinLeagueByCode callable)
  allow write: if false; // Backend only
}

// Per-director league invitations. Invitee can read/list their own
// invitations; inviter can read/list invitations they sent. Writes go
// through callables. `read` covers both get and list: a get is checked
// against the fetched doc, and a list is only allowed when the query
// provably constrains results to the caller (the client must filter with
// where('inviteeUid'=='me') or where('inviterUid'=='me') — see
// getPendingInvitations in src/api/leagues.ts). The previous unconditional
// `allow list: if isAuthenticated()` let any signed-in user dump everyone's
// invitations, defeating the per-doc checks.
match /artifacts/{appId}/leagueInvitations/{invitationId} {
  allow read: if isAuthenticated() && (
    request.auth.uid == resource.data.inviteeUid ||
    request.auth.uid == resource.data.inviterUid ||
    isAdmin()
  );
  allow write: if false; // Backend only
}

// --- MISC & ADMIN ---
match /activeLineups/{lineupKey} {
  allow read, write: if false; // Backend only
}

match /usernames/{username} {
  allow read: if true;
  allow write: if false; // Backend only
}

// Comment reports are created exclusively by the reportComment callable
// (Admin SDK bypasses rules). The previous open create rule let any signed-in
// user write arbitrary documents here — a spam/storage-abuse vector.
match /reports/{reportId} {
  allow read, update: if isAdmin();
  allow create: if false; // Backend only (via reportComment callable)
}

// Season settings (needed for dashboard)
match /season_settings/{docId} {
  allow read: if true;
  allow write: if isAdmin();
}

// Seasons collection (needed for Scores page)
match /seasons/{seasonId} {
  allow read: if true;
  allow write: if isAdmin();
}

// Season schedules (needed for Schedule page)
match /season-schedules/{seasonId} {
  allow read: if true;
  allow write: if isAdmin();

  match /days/{dayId} {
    allow read: if true;
    allow write: if isAdmin();
  }
}

// --- NEWS HUB ---
// Public read access for news content (generated by Gemini AI)
match /news_hub/{newsId} {
  allow read: if true;
  allow write: if false; // Backend only (via Cloud Functions)
}

// Nested news_hub structure: news_hub/{seasonId}/days/{dayId}/articles/{articleType}
// Allow public read access for direct article URLs (shared links)
match /news_hub/{seasonId}/days/{dayId} {
  allow read: if true;
  allow write: if false; // Backend only

  match /articles/{articleType} {
    allow read: if true;
    allow write: if false; // Backend only
  }
}

// Community submissions: news_hub/{seasonId}/community/{articleId}
match /news_hub/{seasonId}/community/{articleId} {
  allow read: if true;
  allow write: if false; // Backend only
}

// Collection group rule for articles - enables direct URL access and collection group queries
// This allows reading any document in any 'articles' subcollection regardless of parent path
match /{path=**}/articles/{articleId} {
  allow read: if true;
  allow write: if false; // Backend only
}

// --- NEWS SUBMISSIONS ---
// User-submitted articles pending admin approval. Created exclusively by the
// submitNewsForApproval callable (Admin SDK bypasses rules), which validates
// and shapes the submission server-side; the previous open create rule let
// any signed-in user write arbitrary documents here.
match /news_submissions/{submissionId} {
  allow read: if isAdmin();
  allow create: if false; // Backend only (via submitNewsForApproval callable)
  allow update, delete: if isAdmin();
}

}}