rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- USER DATA ---
    match /artifacts/{namespace}/users/{userId} {
      // Profile data is readable by anyone (for public profiles), writable only via cloud functions
      // UPDATED: Allow user to write their own uniform data for corps
      match /profile/data {
        allow read: if true; // Profiles are public for leaderboards, leagues, etc.
        allow write: if request.auth != null && request.auth.uid == userId && 
          // Allow updating uniform data for corps
          (resource == null || 
           request.resource.data.keys().hasAll(['corps']) == false ||
           isValidCorpsUniformUpdate(request.resource.data, resource.data));
        allow update: if request.auth != null && request.auth.uid == userId;
      }
      
      // Private data is only accessible to the owner (via cloud functions)
      match /private/data {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // All writes handled by cloud functions
      }
      
      // Subscription data is only accessible to the owner
      match /subscription/data {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Comments are public to read. Logged-in users can create.
      // Deletion handled by cloud functions only
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if false; // Handled by cloud functions only
      }
      
      // Notifications are private to the user
      match /notifications/{notificationId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // --- VALIDATION FUNCTIONS ---
    // Function to validate corps uniform updates
    function isValidCorpsUniformUpdate(newData, oldData) {
      // Allow if user is updating their own corps uniform data
      // Check that they're not changing core game data, only uniform data
      let allowedCorpsFields = ['corpsName', 'lineup', 'totalSeasonScore', 'selectedShows', 'weeklyTrades', 'lastScoredDay', 'lineupKey', 'uniforms'];
      
      // If corps data exists in the update
      return !('corps' in newData) || (
        // All corps classes are valid
        newData.corps.keys().hasAll(['soundSport', 'aClass', 'openClass', 'worldClass'].toSet()) == false &&
        // For each corps class being updated
        newData.corps.keys().hasAll(oldData.get('corps', {}).keys()) &&
        // Only allowed fields are being modified
        isValidCorpsFields(newData.corps, allowedCorpsFields) &&
        // Uniform data is valid
        isValidUniformData(newData.corps)
      );
    }
    
    function isValidCorpsFields(corpsData, allowedFields) {
      return corpsData.keys().hasAll(
        corpsData.keys().toSet().intersection(allowedFields.toSet())
      );
    }
    
    function isValidUniformData(corpsData) {
      // Check each corps class
      return corpsData.keys().hasAll([]).hasAny([
        !('uniforms' in corpsData) || 
        // Uniforms should be indexed 0-3 and contain valid uniform objects
        isValidUniformSlots(corpsData.uniforms)
      ]);
    }
    
    function isValidUniformSlots(uniforms) {
      // Check that uniform slots are valid (0-3) and contain proper uniform data
      let validSlots = ['0', '1', '2', '3'];
      return uniforms.keys().hasAll(validSlots.toSet()) == false &&
             uniforms.keys().hasAny(validSlots) &&
             // Each uniform has required fields if it exists
             isValidUniformObjects(uniforms);
    }
    
    function isValidUniformObjects(uniforms) {
      // Basic validation - each uniform should have name, colors, styles if it exists
      // More detailed validation can be added here
      return true; // Simplified for now - trust client-side validation
    }

    // --- PUBLIC GAME DATA ---
    match /game-settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    match /dci-data/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    match /dci-stats/{docId} {
      allow read: if true;
      allow write: if false; // Backend only
    }
    
    match /fantasy_recaps/{docId} {
      allow read: if true;
      allow write: if false; // Backend only
    }
    
    match /final_rankings/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    match /historical_scores/{docId} {
      allow read: if true;
      allow write: if false; // Backend only
    }
    
    match /live_scores/{seasonId}/scores/{docId} {
      allow read: if true;
      allow write: if false; // Backend only
    }
    
    match /schedules/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // --- LEAGUES ---
    match /leagues/{leagueId} {
      // League members and admins can read league data
      allow read: if request.auth != null && 
        (request.auth.uid in resource.data.members || 
         request.auth.token.admin == true);
      // Only backend functions can write/update league data
      allow write: if false; // Backend only
    }

    // League matchups are readable by authenticated users
    match /leagues/{leagueId}/matchups/{week} {
      allow read: if request.auth != null;
      allow write: if false; // Backend only
    }

    // League invites are handled entirely by backend
    match /leagueInvites/{inviteCode} {
      allow read, write: if false; // Backend only
    }

    // League archives are public to read
    match /league_archives/{archiveId} {
      allow read: if true;
      allow write: if false; // Backend only
    }

    // --- USER MANAGEMENT ---
    match /usernames/{username} {
      allow read: if true; // Needed for username availability checking
      allow write: if false; // Backend only
    }

    match /activeLineups/{lineupKey} {
      allow read, write: if false; // Backend only
    }

    // --- REPORTS AND MODERATION ---
    match /reports/{reportId} {
      allow read, update: if request.auth != null && request.auth.token.admin == true;
      allow create: if request.auth != null;
      allow delete: if false; // Reports should not be deleted
    }

    // --- PAYMENT AND SUBSCRIPTION DATA ---
    match /stripe_customers/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /stripe_subscriptions/{subscriptionId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow write: if false; // Backend only
    }

    // --- ADMIN DATA ---
    match /admin/{docId} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }

    // --- SYSTEM LOGS (for debugging and analytics) ---
    match /system_logs/{logId} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }

    // --- NOTIFICATION SYSTEM ---
    match /notifications/{userId}/messages/{messageId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // --- PERFORMANCE OPTIMIZATIONS ---
    // Allow reading game data for dashboard performance
    match /fantasy_recaps/{docId} {
      allow read: if true; // Allow reading recap data for dashboard
    }
    
    match /dci-data/{docId} {
      allow read: if true; // Allow reading DCI data
    }
    
    match /game-settings/{docId} {
      allow read: if true; // Allow reading game settings
    }

    // Default deny rule for security - this should be last
    match /{document=**} {
      allow read, write: if false;
    }
  }
}