rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- COLLECTION GROUP QUERIES FOR LEADERBOARDS ---
    // CRITICAL: This must be at the top to allow collection group queries on 'data' documents
    // But only for profile data within the artifacts namespace
    match /artifacts/{namespace}/users/{userId}/profile/data {
      allow read: if true; // Public profiles for leaderboards
    }
    
    // Allow collection group queries on 'data' collection but restrict to profile data
    match /{path=**}/data {
      allow read: if true; // This enables collectionGroup(db, 'data') queries
    }

    // --- STAFF COLLECTION (HALL OF FAME DATABASE) ---
    // Hall of Fame staff database - read-only for all authenticated users
    match /staff/{staffId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // --- STAFF MARKETPLACE COLLECTION ---
    // Staff marketplace listings - users can create listings, all can read active ones
    match /staff_marketplace/{listingId} {
      allow read: if request.auth != null && resource.data.isActive == true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.sellerId;
      allow update: if request.auth != null && 
        (request.auth.uid == resource.data.sellerId || request.auth.token.admin == true);
      allow delete: if request.auth != null && 
        (request.auth.uid == resource.data.sellerId || request.auth.token.admin == true);
    }

    // --- CORPS COIN TRANSACTIONS ---
    // Transaction logs for CorpsCoin spending and earning
    match /corps_coin_transactions/{userId}/transactions/{transactionId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // All transactions handled by cloud functions
    }

    // --- XP TRANSACTIONS ---
    // XP earning and spending logs
    match /xp_transactions/{userId}/transactions/{transactionId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // All transactions handled by cloud functions
    }

    // --- USER DATA ---
    match /artifacts/{namespace}/users/{userId} {
      // Profile data is readable by anyone (for public profiles, leaderboards, leagues, etc.)
      // Users can update their own profile data including uniforms and lastActive
      match /profile/data {
        allow read: if true; // Profiles are public for leaderboards, leagues, etc.
        allow write, update: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId;
      }
      
      // Allow reading the user document itself for league member queries
      allow read: if true; // Needed for league member lookups and leaderboards
      
      // Private data is only accessible to the owner
      match /private/data {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // All writes handled by cloud functions
      }
      
      // Subscription data is only accessible to the owner
      match /subscription/data {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // User staff collection - only owner can read, writes handled by cloud functions
      match /staff/{staffId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // All staff operations handled by cloud functions
      }
      
      // Comments are public to read. Logged-in users can create.
      match /comments/{commentId} {
        allow read: if true; // Comments are public for profiles
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && 
          (request.auth.uid == resource.data.authorId || request.auth.token.admin == true);
      }
      
      // Notifications - only accessible to the owner
      match /notifications/{notificationId} {
        allow read, update: if request.auth != null && request.auth.uid == userId;
        allow create, delete: if false; // Handled by cloud functions
      }
    }

    // --- GAME DATA ---
    match /dci-data/{seasonId}/{document=**} {
      allow read: if true; // Season data is public
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    match /historical_scores/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    match /live_scores/{seasonId}/scores/{docId} {
      allow read: if true;
      allow write: if false; // Backend only
    }
    
    match /schedules/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // --- LEADERBOARDS ---
    match /leaderboards/{seasonId}/rankings/{docId} {
      allow read: if true;
      allow write: if false; // Backend only
    }

    // --- FANTASY RECAPS ---
    match /fantasy_recaps/{seasonId}/recaps/{docId} {
      allow read: if true;
      allow write: if false; // Backend only
    }

    // --- LEAGUES (Enhanced with proper permissions) ---
    match /leagues/{leagueId} {
      // League members and admins can read league data
      allow read: if request.auth != null && 
        (request.auth.uid in resource.data.members || 
         request.auth.token.admin == true);
      // Only backend functions can write/update league data
      allow create, update, delete: if false; // Backend only
    }

    // League matchups are readable by authenticated users (for leaderboards and league pages)
    match /leagues/{leagueId}/matchups/{week} {
      allow read: if request.auth != null;
      allow write: if false; // Backend only
    }

    // League chat messages - members can read/write, enhanced permissions
    match /leagues/{leagueId}/chat/{messageId} {
      allow read: if request.auth != null && 
        (request.auth.uid in get(/databases/$(database)/documents/leagues/$(leagueId)).data.members ||
         request.auth.token.admin == true);
      allow create: if request.auth != null && 
        request.auth.uid in get(/databases/$(database)/documents/leagues/$(leagueId)).data.members;
      allow update, delete: if false; // Backend only
    }

    // League invitations
    match /league_invitations/{invitationId} {
      allow read: if request.auth != null && 
        (request.auth.uid == resource.data.inviteeId || 
         request.auth.uid == resource.data.inviterId ||
         request.auth.token.admin == true);
      allow write: if false; // Backend only
    }

    // --- ADMIN COLLECTIONS ---
    match /admin/{document=**} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }

    // System settings and configurations
    match /system/{document=**} {
      allow read: if true; // System settings can be read by all
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Error logs and analytics (admin only)
    match /logs/{document=**} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }

    // --- DEFAULT DENY ---
    // Explicitly deny access to any collection not covered above
    match /{document=**} {
      allow read, write: if false;
    }
  }
}