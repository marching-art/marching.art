rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- COLLECTION GROUP QUERIES FOR LEADERBOARDS ---
    // Allow collection group queries on 'data' collection but restrict to profile data
    match /{path=**}/data {
      allow read: if true; // This enables collectionGroup(db, 'data') queries
    }

    // --- STAFF MARKETPLACE COLLECTION ---
    // Staff marketplace listings - users can create listings, all can read active ones
    match /staff_marketplace/{listingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.sellerId;
      allow update: if request.auth != null && 
        (request.auth.uid == resource.data.sellerId || request.auth.token.admin == true);
      allow delete: if request.auth != null && 
        (request.auth.uid == resource.data.sellerId || request.auth.token.admin == true);
    }

    // --- USER DATA ---
    match /artifacts/{namespace}/users/{userId} {
      // Profile data is readable by anyone (for public profiles, leaderboards, leagues, etc.)
      // Users can update their own profile data including uniforms and lastActive
      match /profile/data {
        allow read: if true; // Profiles are public for leaderboards, leagues, etc.
        allow write, update: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId;
      }
      
      // Allow reading the user document itself for league member queries
      allow read: if true; // Needed for league member lookups and leaderboards
      
      // Private data is only accessible to the owner
      match /private/data {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // All writes handled by cloud functions
      }
      
      // Subscription data is only accessible to the owner
      match /subscription/data {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // User staff collection - only owner can read, writes handled by cloud functions
      match /staff/{staffId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // All staff operations handled by cloud functions
      }
      
      // Comments are public to read. Logged-in users can create.
      // Deletion handled by cloud functions only
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if false; // Handled by cloud functions only
      }
      
      // Notifications are private to the user
      match /notifications/{notificationId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // --- STAFF MANAGEMENT ---
    // Hall of Fame Staff Database - public read access, admin write access
    match /staff/{staffId} {
      allow read: if true; // Public access for staff market
      allow create, update, delete: if request.auth != null && request.auth.token.admin == true;
    }

    // --- SEASON AND GAME DATA ---
    match /game-settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    match /seasons/{seasonId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
      
      // Season-specific data subcollections
      match /{path=**} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.token.admin == true;
      }
    }
    
    match /dci-data/{seasonId} {
      // Allow admins to write to the top-level season documents
      allow write: if request.auth != null && request.auth.token.admin == true;

      // Allow anyone to read any document within this season or its subcollections
      match /{path=**} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.token.admin == true;
      }
    }
    
    match /dci-stats/{docId} {
      allow read: if true;
      allow write: if false; // Backend only
    }
    
    match /fantasy_recaps/{docId} {
      allow read: if true;
      allow write: if false; // Backend only
      
      // Fantasy recap subcollections (results, details, etc.)
      match /{path=**} {
        allow read: if true;
        allow write: if false; // Backend only
      }
    }
    
    match /final_rankings/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    match /historical_scores/{docId} {
      allow read: if true;
      allow write: if false; // Backend only
      
      // Historical score subcollections
      match /{path=**} {
        allow read: if true;
        allow write: if false; // Backend only
      }
    }
    
    match /live_scores/{seasonId}/scores/{docId} {
      allow read: if true;
      allow write: if false; // Backend only
    }
    
    match /schedules/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // --- LEAGUES ---
    match /leagues/{leagueId} {
      // League members and admins can read league data
      allow read: if request.auth != null;
      // Only backend functions can write/update league data
      allow create, update, delete: if false; // Backend only
    }

    // League matchups are readable by authenticated users
    match /leagues/{leagueId}/matchups/{week} {
      allow read: if request.auth != null;
      allow write: if false; // Backend only
    }

    // League chat messages - members can read/write
    match /leagues/{leagueId}/chat/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false; // Backend only
    }

    // League invitations
    match /league_invitations/{inviteId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // League join requests
    match /league_join_requests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if false; // Backend only
    }

    // League archives are public to read
    match /league_archives/{archiveId} {
      allow read: if true;
      allow write: if false; // Backend only
    }

    // League stats and summaries - public read access
    match /league_stats/{leagueId} {
      allow read: if true;
      allow write: if false; // Backend only
    }

    // League member data aggregation
    match /league_members/{leagueId}/{memberId} {
      allow read: if request.auth != null;
      allow write: if false; // Backend only
    }

    // --- ADDITIONAL GAME DATA COLLECTIONS ---
    match /uniform_presets/{presetId} {
      allow read: if true; // Public uniform presets
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // CorpsCoin transactions
    match /corpscoin_transactions/{transactionId} {
      allow read: if request.auth != null && 
        (request.auth.uid == resource.data.userId || request.auth.token.admin == true);
      allow write: if false; // Backend only
    }

    // Performance tracking
    match /performance_history/{userId} {
      match /performances/{performanceId} {
        allow read: if request.auth != null && 
          (request.auth.uid == userId || request.auth.token.admin == true);
        allow write: if false; // Backend only
      }
    }

    // Hall of Champions
    match /hall_of_champions/{championshipId} {
      allow read: if true; // Public access to championship records
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Scoring and calculations
    match /scoring_data/{seasonId}/{week} {
      allow read: if true;
      allow write: if false; // Backend only
    }

    // Weekly lineup snapshots for scoring
    match /lineup_snapshots/{seasonId}/{week}/{userId} {
      allow read: if request.auth != null && 
        (request.auth.uid == userId || request.auth.token.admin == true);
      allow write: if false; // Backend only
    }

    // XP and progression
    match /xp_transactions/{userId} {
      match /transactions/{transactionId} {
        allow read: if request.auth != null && 
          (request.auth.uid == userId || request.auth.token.admin == true);
        allow write: if false; // Backend only
      }
    }

    // Class unlocking requirements
    match /class_requirements/{requirementId} {
      allow read: if true; // Public access to class requirements
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // --- ADMINISTRATIVE COLLECTIONS ---
    // Admin can write to any collection for management purposes
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}