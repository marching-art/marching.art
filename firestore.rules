rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- COLLECTION GROUP QUERIES FOR LEADERBOARDS ---
    match /artifacts/{namespace}/users/{userId}/profile/data {
      allow read: if true; // Public profiles for leaderboards
    }
    
    match /{path=**}/data {
      allow read: if true; // Enable collectionGroup queries
    }

    // --- ADMIN ACCESS ---
    match /{document=**} {
      allow read, write: if request.auth != null && 
        request.auth.uid == "o8vfRCOevjTKBY0k2dISlpiYiIH2";
    }

    // --- HELPER FUNCTIONS ---
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.admin == true || request.auth.uid == "o8vfRCOevjTKBY0k2dISlpiYiIH2");
    }

    // --- USER DATA ---
    match /artifacts/{namespace}/users/{userId} {
      // Profile data - users can read and write their own
      match /profile/data {
        allow read: if true; // Public for leaderboards
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if false; // Never allow deletion
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Corps subcollection - users can manage their own corps
      match /corps/{corpsId} {
        allow read: if isAuthenticated();
        allow create, update: if isOwner(userId);
        allow delete: if isOwner(userId) || isAdmin();
      }

      // Staff collection
      match /staff/{staffId} {
        allow read: if isAuthenticated();
        allow create, update, delete: if isOwner(userId);
      }

      // Notifications
      match /notifications/{notificationId} {
        allow read: if isOwner(userId);
        allow update: if isOwner(userId) && 
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt']);
        allow create: if false; // Only cloud functions
        allow delete: if isOwner(userId);
      }

      // Generic subcollections
      match /{collection}/{document=**} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId);
      }
    }

    // --- PUBLIC DATA COLLECTIONS ---
    match /game-settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /dci-data/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /dci-stats/{document=**} {
      allow read: if true;
      allow write: if false; // Backend only
    }
    
    match /schedules/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /live_scores/{document=**} {
      allow read: if true;
      allow write: if false; // Backend only
    }
    
    match /historical_scores/{document=**} {
      allow read: if true;
      allow write: if false; // Backend only
    }
    
    match /fantasy_recaps/{document=**} {
      allow read: if true;
      allow write: if false; // Backend only
    }
    
    match /final_rankings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /seasonal_scores/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /season-archives/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // --- PARTICIPANTS ---
    match /participants/{participantId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // --- LEADERBOARDS ---
    match /leaderboards/{document=**} {
      allow read: if true;
      allow write: if false; // Backend only
    }
    
    match /season-results/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- LEAGUES ---
    match /leagues/{leagueId} {
      allow read: if isAuthenticated() && 
        (request.auth.uid in resource.data.members || isAdmin());
      allow create, update, delete: if false; // Backend only
    }

    match /leagues/{leagueId}/matchups/{week} {
      allow read: if isAuthenticated();
      allow write: if false; // Backend only
    }

    match /leagues/{leagueId}/chat/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
        request.resource.data.senderId == request.auth.uid;
      allow update, delete: if false; // Messages immutable
    }

    match /league_invitations/{inviteId} {
      allow read: if isAuthenticated() && 
        (request.auth.uid == resource.data.inviteeId || 
         request.auth.uid == resource.data.inviterId || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && 
        (request.auth.uid == resource.data.inviteeId || 
         request.auth.uid == resource.data.inviterId);
      allow delete: if isAuthenticated() && 
        (request.auth.uid == resource.data.inviterId || isAdmin());
    }

    match /league_join_requests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if false; // Backend only
    }

    // --- STAFF MARKETPLACE ---
    match /staff_marketplace/{listingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.sellerId;
      allow update: if isAuthenticated() && 
        (request.auth.uid == resource.data.sellerId || isAdmin());
      allow delete: if isAuthenticated() && 
        (request.auth.uid == resource.data.sellerId || isAdmin());
    }

    // --- TRANSACTIONS ---
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && 
                    (resource.data.buyerId == request.auth.uid || 
                     resource.data.sellerId == request.auth.uid);
      allow write: if false; // Backend only
    }

    match /corps_coin_transactions/{userId}/transactions/{transactionId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false; // Backend only
    }

    match /xp_transactions/{userId}/transactions/{transactionId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false; // Backend only
    }

    // --- HALL OF FAME ---
    match /hall-of-fame/{memberId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- STAFF DATABASE ---
    match /staff-database/{staffId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- ACHIEVEMENTS ---
    match /achievements/{userId}/{achievementId} {
      allow read: if isAuthenticated();
      allow write: if false; // Backend only
    }

    // --- NOTIFICATIONS (GLOBAL) ---
    match /notifications/{userId}/{notificationId} {
      allow read: if isOwner(userId);
      allow update: if isOwner(userId) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt']);
      allow create: if false; // Backend only
      allow delete: if isOwner(userId);
    }

    // --- ANALYTICS & LOGS (Admin only) ---
    match /analytics/{document=**} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /system-logs/{document=**} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /error-logs/{document=**} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // --- DEFAULT DENY ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}