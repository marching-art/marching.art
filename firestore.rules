rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- COLLECTION GROUP QUERIES FOR LEADERBOARDS ---
    // CRITICAL: This must be at the top to allow collection group queries on 'data' documents
    // But only for profile data within the artifacts namespace
    match /artifacts/{namespace}/users/{userId}/profile/data {
      allow read: if true; // Public profiles for leaderboards
    }
    
    // Allow collection group queries on 'data' collection but restrict to profile data
    match /{path=**}/data {
      allow read: if true; // This enables collectionGroup(db, 'data') queries
    }

    // --- ADMIN ACCESS ---
    // Admin user gets full read/write access to everything
    match /{document=**} {
      allow read, write: if request.auth != null && 
        request.auth.uid == "o8vfRCOevjTKBY0k2dISlpiYiIH2";
    }

    // --- HELPER FUNCTIONS ---
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.admin == true || request.auth.uid == "o8vfRCOevjTKBY0k2dISlpiYiIH2");
    }
    
    function hasValidSeason() {
      return exists(/databases/$(database)/documents/game-settings/current);
    }

    // --- STAFF MARKETPLACE COLLECTION ---
    // Staff marketplace listings - users can create listings, all can read active ones
    match /staff_marketplace/{listingId} {
      allow read: if request.auth != null && resource.data.isActive == true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.sellerId;
      allow update: if request.auth != null && 
        (request.auth.uid == resource.data.sellerId || isAdmin());
      allow delete: if request.auth != null && 
        (request.auth.uid == resource.data.sellerId || isAdmin());
    }

    // --- USER DATA ---
    match /artifacts/{namespace}/users/{userId} {
      // Profile data is readable by anyone (for public profiles, leaderboards, leagues, etc.)
      // Users can update their own profile data including uniforms and lastActive
      match /profile/data {
        allow read: if true; // Profiles are public for leaderboards, leagues, etc.
        allow create: if isOwner(userId);
        allow update: if isOwner(userId) && 
                        request.resource.data.keys().hasAll(['corps', 'stats', 'settings']) &&
                        request.resource.data.uid == userId;
        allow delete: if false; // Never allow deletion of profiles
      }

      // Staff collection
      match /staff/{staffId} {
        allow read: if request.auth != null;
        allow create: if isOwner(userId);
        allow update, delete: if isOwner(userId);
      }

      // Notifications collection
      match /notifications/{notificationId} {
        allow read: if isOwner(userId);
        allow update: if isOwner(userId) && 
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt']);
        allow create: if false; // Only cloud functions can create
        allow delete: if isOwner(userId);
      }

      // Trading cards collection
      match /cards/{cardId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId);
      }

      // User settings
      match /settings/{document} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId);
      }

      // User collections (generic catch-all for other collections)
      match /{collection}/{document} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId);
      }
    }

    // --- PUBLIC DATA COLLECTIONS ---
    
    // Game Settings - Public read, admin write
    match /game-settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // DCI Data - Public read, admin write
    match /dci-data/{seasonId} {
      allow read: if true;
      allow write: if isAdmin();
      
      // Allow reading subcollections
      match /{path=**} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }
    
    // DCI Stats
    match /dci-stats/{docId} {
      allow read: if true;
      allow write: if false; // Backend only
    }
    
    // Schedules - Public read, admin write
    match /schedules/{seasonId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Live Scores
    match /live_scores/{seasonId}/scores/{docId} {
      allow read: if true;
      allow write: if false; // Backend only
    }
    
    // Historical Scores
    match /historical_scores/{docId} {
      allow read: if true;
      allow write: if false; // Backend only
    }
    
    // Fantasy Recaps
    match /fantasy_recaps/{docId} {
      allow read: if true;
      allow write: if false; // Backend only
    }
    
    // Final Rankings
    match /final_rankings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Seasonal Scores - pre-computed scores for efficiency
    match /seasonal_scores/{seasonId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Season Archives - historical season data
    match /season-archives/{seasonId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // --- PARTICIPANTS (SHOW REGISTRATION) ---
    match /participants/{participantId} {
      // Anyone can read to see who's registered for shows
      allow read: if isAuthenticated();
      // Only cloud functions can create/update participants
      allow create: if false; // Backend only via cloud functions
      allow update: if false; // Backend only
      allow delete: if false; // Backend only
    }

    // --- LEADERBOARDS ---
    match /leaderboards/{leaderboardId} {
      allow read: if true;
      allow write: if false; // Only cloud functions can update
    }
    
    // Season Results
    match /season-results/{seasonId}/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- LEAGUES ---
    match /leagues/{leagueId} {
      // League members and admins can read league data
      allow read: if request.auth != null && 
        (request.auth.uid in resource.data.members || isAdmin());
      // Only backend functions can write/update league data
      allow create, update, delete: if false; // Backend only
    }

    // League matchups are readable by authenticated users
    match /leagues/{leagueId}/matchups/{week} {
      allow read: if request.auth != null;
      allow write: if false; // Backend only
    }

    // League chat messages
    match /leagues/{leagueId}/chat/{messageId} {
      allow read: if request.auth != null && 
        (request.auth.uid in get(/databases/$(database)/documents/leagues/$(leagueId)).data.members || isAdmin());
      allow create: if request.auth != null && 
        request.auth.uid in get(/databases/$(database)/documents/leagues/$(leagueId)).data.members &&
        request.resource.data.senderId == request.auth.uid;
      allow update, delete: if false; // Messages are immutable
    }

    // League invitations
    match /league_invitations/{inviteId} {
      allow read: if request.auth != null && 
        (request.auth.uid == resource.data.inviteeId || 
         request.auth.uid == resource.data.inviterId || isAdmin());
      allow create: if request.auth != null;
      allow update: if request.auth != null && 
        (request.auth.uid == resource.data.inviteeId || 
         request.auth.uid == resource.data.inviterId);
      allow delete: if request.auth != null && 
        (request.auth.uid == resource.data.inviterId || isAdmin());
    }

    // League join requests
    match /league_join_requests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if false; // Backend only
    }

    // League archives
    match /league_archives/{archiveId} {
      allow read: if true;
      allow write: if false; // Backend only
    }

    // League stats and summaries
    match /league_stats/{leagueId} {
      allow read: if true;
      allow write: if false; // Backend only
    }

    // League member data aggregation
    match /league_members/{leagueId}/{memberId} {
      allow read: if request.auth != null;
      allow write: if false; // Backend only
    }

    // --- MARKETPLACE ---
    match /marketplace/{listingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                      request.resource.data.sellerId == request.auth.uid &&
                      request.resource.data.status == 'active';
      allow update: if isOwner(resource.data.sellerId) && 
                      resource.data.status != 'completed';
      allow delete: if isOwner(resource.data.sellerId) && 
                      resource.data.status == 'active';
    }

    // --- TRANSACTIONS ---
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && 
                    (resource.data.buyerId == request.auth.uid || 
                     resource.data.sellerId == request.auth.uid);
      allow write: if false; // Only cloud functions can write
    }

    // CorpsCoin Transactions
    match /corps_coin_transactions/{userId}/transactions/{transactionId} {
      allow read: if request.auth != null && 
        (request.auth.uid == userId || isAdmin());
      allow write: if false; // Backend only
    }

    // XP Transactions
    match /xp_transactions/{userId}/transactions/{transactionId} {
      allow read: if request.auth != null && 
        (request.auth.uid == userId || isAdmin());
      allow write: if false; // Backend only
    }

    // --- CHAT/MESSAGES ---
    match /messages/{conversationId}/{messageId} {
      allow read: if isAuthenticated() && 
                    request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && 
                      request.auth.uid in request.resource.data.participants &&
                      request.resource.data.senderId == request.auth.uid;
      allow update: if false; // Messages are immutable
      allow delete: if false;
    }

    // --- ANALYTICS ---
    match /analytics/{document=**} {
      allow read: if isAdmin();
      allow write: if false; // Only cloud functions
    }

    // --- FEATURE FLAGS ---
    match /feature-flags/{flag} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- SEASON ARCHIVES ---
    match /archives/{seasonId}/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- NOTIFICATIONS (GLOBAL) ---
    match /notifications/{userId}/{notificationId} {
      allow read: if isOwner(userId);
      allow update: if isOwner(userId) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt']);
      allow create: if false; // Only cloud functions can create
      allow delete: if isOwner(userId);
    }

    // --- HALL OF FAME ---
    match /hall-of-fame/{memberId} {
      allow read: if true; // Public data
      allow write: if isAdmin();
    }

    // --- STAFF DATABASE ---
    match /staff-database/{staffId} {
      allow read: if true; // Public data
      allow write: if isAdmin();
    }

    // --- USER ACHIEVEMENTS ---
    match /achievements/{userId}/{achievementId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only cloud functions can award achievements
    }

    // --- SEASON CONFIGURATION ---
    match /season-config/{seasonId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- SYSTEM LOGS (Admin only) ---
    match /system-logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Only cloud functions
    }

    // --- ERROR LOGS ---
    match /error-logs/{errorId} {
      allow read: if isAdmin();
      allow write: if false; // Only cloud functions
    }

    // --- BACKUP DATA ---
    match /backups/{backupId}/{document=**} {
      allow read: if isAdmin();
      allow write: if false; // Only automated backups
    }
  }
}