    "axios": "^1.18.1",
    "cheerio": "^1.2.0",
    "cloudinary": "^2.10.0",
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.3.0"
  },
  "devDependencies": {
    "firebase-functions-test": "^3.5.0"
  }
